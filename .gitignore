# Monorepo packages / generated clients
# ------------------------------------------------------------------------------
packages/api-client/generated/**
!packages/api-client/generated/.gitkeep
packages/ui/dist/
packages/ui/build/
packages/config/dist/
packages/spec-types/dist/
packages/test-utils/dist/
packages/shared-types/dist/

# ------------------------------------------------------------------------------
# Specs / compiled plans / validation output
# ------------------------------------------------------------------------------
specs/generated/**
!specs/generated/.gitkeep

# If schemas are source-of-truth, keep them. Ignore only transient validation output:
specs/schema/**/*.compiled.*
specs/schema/**/*.cache.*
specs/schema/.cache/

# ------------------------------------------------------------------------------
# Agent workspace outputs
# ------------------------------------------------------------------------------
agents/**/.cache/
agents/**/dist/
agents/**/build/
agents/**/coverage/
agents/**/.pytest_cache/
agents/**/.mypy_cache/
agents/**/.ruff_cache/

# Agent scratchpads / temp prompt outputs
agents/**/tmp/
agents/**/temp/
agents/**/runs/
agents/**/artifacts/
!agents/**/.gitkeep

# ------------------------------------------------------------------------------
# Scripts / local execution outputs
# ------------------------------------------------------------------------------
scripts/**/.cache/
scripts/**/tmp/
scripts/**/temp/

# ------------------------------------------------------------------------------
# Deployment / release outputs
# ------------------------------------------------------------------------------
deployment/releases/manifests/**
!deployment/releases/manifests/.gitkeep
deployment/releases/notes/**
!deployment/releases/notes/.gitkeep
deployment/releases/checksums/**
!deployment/releases/checksums/.gitkeep

# Local environment files inside deployment folders
deployment/environments/**/.env
deployment/environments/**/.env.*
!deployment/environments/**/.env.example
!deployment/environments/**/.env.*.example

# Smoke outputs
deployment/smoke/**/*.log

# ------------------------------------------------------------------------------
# Preserve empty scaffolding folders with .gitkeep
# ------------------------------------------------------------------------------
!**/.gitkeep
