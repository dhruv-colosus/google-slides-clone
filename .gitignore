!apps/web/src/generated/.gitkeep

# ------------------------------------------------------------------------------
# Playwright / browser automation
# ------------------------------------------------------------------------------
playwright-report/
blob-report/
test-results/
test-artifacts/
.trace/
traces/
videos/
screenshots/
snapshots/
*.trace
*.har
*.webm
*.mp4

# Keep stable intentional snapshots only if you choose to version them.
# By default ignore all generated snapshot artifacts:
**/__screenshots__/
**/__image_snapshots__/
**/__diff_output__/
**/playwright/.cache/

# Raw target/clone capture artifacts are usually huge and should not be versioned.
research/raw/**
!research/raw/.gitkeep

# If you want normalized manifests versioned, keep them.
# Reports are generally generated and should be ignored.
research/reports/**
!research/reports/.gitkeep

# Generated diffs / parity outputs
generated/diffs/**
!generated/diffs/.gitkeep

# Generated codegen outputs: keep or ignore based on your workflow.
# Default here: ignore machine-generated intermediate codegen artifacts,
# but keep committed app code in apps/.
generated/codegen/**
!generated/codegen/.gitkeep
generated/manifests/**
!generated/manifests/.gitkeep

