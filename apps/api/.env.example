DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/slidesdb
SECRET_KEY=generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

FRONTEND_URL=http://localhost:3000
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Playwright e2e tests: set to true ONLY in local/test envs.
# Enables POST /auth/test-login which issues a JWT cookie for a seeded test user
# without going through Google OAuth. Must stay false in production.
TEST_AUTH_ENABLED=false
TEST_AUTH_EMAIL=playwright-e2e@example.com
TEST_AUTH_NAME=Playwright Test
