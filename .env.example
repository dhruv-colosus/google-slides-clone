# Container registry (GHCR) — lowercase GitHub username/org
GHCR_OWNER=your-github-username
IMAGE_TAG=latest

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_random
POSTGRES_DB=slidesdb

# Backend (FastAPI) — connects to the `db` service on the compose network
DATABASE_URL=postgresql+asyncpg://postgres:change_me_strong_random@db:5432/slidesdb

# JWT
SECRET_KEY=generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://slides.dhruvdeora.com/api/auth/callback

# Public URLs / cookies
FRONTEND_URL=https://slides.dhruvdeora.com
COOKIE_DOMAIN=slides.dhruvdeora.com
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Local-only Google OAuth bypass — keep TEST_AUTH_ENABLED=false in production.
# When true, POST /auth/test-login issues a session cookie for TEST_AUTH_EMAIL
# without going through Google. Flipped on by docker-compose.fresh.yml.
TEST_AUTH_ENABLED=false
TEST_AUTH_EMAIL=playwright-e2e@example.com
TEST_AUTH_NAME=Playwright Test

# Admin endpoints (POST /admin/reset, POST /admin/seed). Leave unset/empty in
# production to make /admin/* return 404. When set, callers must send the value
# in the X-Admin-Key header.
ADMIN_API_KEY=
